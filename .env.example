# =============================================================================
# grile-ReziNOTE — required environment variables
# =============================================================================
# Copy this file to `.env.local` for local development, and set the same vars
# in your production host (Railway, Vercel, etc).
#
# Anything marked OPTIONAL has a sensible default but is recommended in prod.

# -----------------------------------------------------------------------------
# Database — Postgres (Railway, Supabase, or self-hosted)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:port/dbname

# -----------------------------------------------------------------------------
# NextAuth.js
# -----------------------------------------------------------------------------
# Generate with: npx auth secret
AUTH_SECRET=
# Public origin of your app (no trailing slash). On Railway/Vercel this is your
# canonical URL — set it in production. Locally, http://localhost:3000.
AUTH_URL=http://localhost:3000
# Required when running behind a proxy (Railway, Cloudflare, Vercel custom). Set
# to "true" in production so NextAuth trusts the X-Forwarded-* headers.
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# App URL — used by Stripe redirects, email links, CSRF same-origin checks
# -----------------------------------------------------------------------------
# Pick ONE of these (we read in this priority order: APP_URL → SITE_URL → AUTH_URL).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google OAuth (for "Continue with Google")
# -----------------------------------------------------------------------------
# Create at https://console.cloud.google.com (OAuth 2.0 Client IDs).
# Authorized redirect URI: <APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Stripe — payments and subscriptions
# -----------------------------------------------------------------------------
# Test keys for dev (sk_test_*, pk_test_*); live keys for prod.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — one per (tier, billing-cycle) combination.
# Create the products + prices in the Stripe Dashboard (see STRIPE_SETUP.md).
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Email — Resend (transactional emails: password reset, welcome, payment failed)
# -----------------------------------------------------------------------------
# Sign up at https://resend.com (free tier: 3,000 emails/month, 100/day).
# Verify your domain in the Resend dashboard before going live, otherwise sends
# only work to your own verified address.
RESEND_API_KEY=re_...
# OPTIONAL — defaults to: grile-ReziNOTE <noreply@grile-rezinote.ro>
# Use the verified sender on your domain.
# EMAIL_FROM="grile-ReziNOTE <noreply@grile-rezinote.ro>"

# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting (login, signup, password reset, webhook)
# -----------------------------------------------------------------------------
# Sign up at https://upstash.com (free tier sufficient).
# The rate limiter throws on import if these are missing — required for boot.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=
